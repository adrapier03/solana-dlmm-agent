# ===== Telegram =====
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ===== RPC / APIs =====
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_API_KEY=YOUR_HELIUS_API_KEY
JUPITER_API_KEY=YOUR_JUPITER_API_KEY

# ===== Position config =====
BUDGET_SOL=0.5
MAX_POSITIONS=1
RANGE_BINS=70

# ===== Filter token =====
# NOTE: MIN_MC & MIN_VOL_5M tidak dipakai (token sudah pre-filter dari JSON source)
MAX_PRICE_CHANGE_5M=15
MAX_PRICE_CHANGE_1H=100
MIN_POOL_LIQUIDITY=40000

# ===== TP/SL =====
STOP_LOSS_PCT=20
TAKE_PROFIT_PCT=10
OUT_OF_RANGE_LIMIT_MIN=30
FEE_CLAIM_THRESHOLD_SOL=0.03

# ===== Auto-swap =====
AUTO_SWAP=true
MAX_SLIPPAGE_BPS=300

# ===== OOR limits (direction-based) =====
OOR_ABOVE_LIMIT_MIN=60
OOR_BELOW_LIMIT_MIN=20

# ===== Volume dry check =====
VOL_DRY_THRESHOLD_USD=10000
VOL_DRY_CYCLES=6

# ===== GMGN response path =====
GMGN_JSON_PATH=/root/solana-dlmm-project/gmgn-script/gmgn_api_response.json

# ===== Cycle =====
CYCLE_INTERVAL_SEC=120

# ===== Cookin.fun scraper =====
# Isi cookie valid kalau mau aktifkan full cookin scraper
COOKIN_COOKIE=YOUR_COOKIN_COOKIE
COOKIN_MIN_SCORE=20
COOKIN_MAX_DUMPERS=60
COOKIN_MAX_BOTS=70
COOKIN_MAX_HOLD_UNDER1MIN=80
COOKIN_MIN_PUMP_CONDITIONS=1
COOKIN_MAX_DUMP_CONDITIONS_PCT=60

# ===== AI skip-cache (hindari evaluasi token yang sama berulang) =====
AI_SKIP_RETRY_MIN=30
AI_SKIP_REEVAL_MC_CHANGE_PCT=30
AI_SKIP_REEVAL_VOL_CHANGE_PCT=50
AI_SKIP_NOTIFY_COOLDOWN_MIN=10
